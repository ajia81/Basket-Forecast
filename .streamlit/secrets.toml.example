# 이 파일을 secrets.toml 로 복사해 실제 키를 채우세요. secrets.toml 은 절대 커밋 금지(.gitignore).
# Streamlit Cloud 배포 시: Settings → Secrets 에 아래 키를 입력(§7-3).
#
# 실연동은 data.go.kr serviceKey 1개면 충분합니다(가격·반입량·표준코드 모두
# 같은 기관 B552845). ⚠️ 반드시 "일반 인증키(Decoding)" 값을 넣으세요 —
# Encoding 키를 넣으면 이중 인코딩으로 인증(SERVICE_KEY) 오류가 납니다.
DATA_GO_KR_KEY = "your-data-go-kr-decoding-service-key"

# (선택) KAMIS 직통키 — verify_catalog_codes 코드 점검에만 쓰입니다. 없어도 됩니다.
# KAMIS_CERT_KEY = "your-kamis-cert-key"
# KAMIS_CERT_ID  = "your-kamis-cert-id"
